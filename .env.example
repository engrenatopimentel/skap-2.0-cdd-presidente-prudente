# Local dev: a SQLite file. Production (Turso): libsql://<db-name>-<org>.turso.io
DATABASE_URL="file:./data/skap.db"

# Only needed when DATABASE_URL is a libsql:// (Turso) URL. Leave empty for local dev.
TURSO_AUTH_TOKEN=""

# Long random string — generate with: openssl rand -base64 32
SESSION_SECRET="change-me-to-a-long-random-string-in-production"

# Only used by `npm run import`, points to the folder with the Power BI xlsx exports.
IMPORT_SOURCE_DIR="../"
